# =============================================
# LMS BACKEND - ENVIRONMENT CONFIGURATION
# TS Academy Capstone - Group 1
# =============================================

# Server
NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb+srv://learningmanagementsystem26_db_user:learningmanagement2026@cluster0.d1zup5j.mongodb.net/lms_db?appName=Cluster0&retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://learningmanagementsystem26_db_user:learningmanagement2026@cluster0.d1zup5j.mongodb.net/lms_db?appName=Cluster0&retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_change_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_token_secret_key_change_in_production
JWT_REFRESH_EXPIRES_IN=7d

# Email (NodeMailer / SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your.email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=LMS Academy <noreply@lmsacademy.com>

# Cloudinary (Media Storage)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Stripe (Payments)
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:5000/api/v1/auth/github/callback

# Frontend URL (for CORS and email links)
FRONTEND_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_AUTH=100
RATE_LIMIT_PUBLIC=20

# Instructor Revenue Share (%)
INSTRUCTOR_REVENUE_SHARE=70

# Certificate Completion Threshold (%)
CERTIFICATE_THRESHOLD=80

# Swagger Docs Password (basic auth for prod)
SWAGGER_USER=admin
SWAGGER_PASS=changeme
